# ==============================================================================
# FLUXVERDE — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore
# ==============================================================================

# ── DATABASE ───────────────────────────────────────────────────────────────────
DB_PASSWORD=change_this_to_a_strong_password_min_32_chars

# ── PGADMIN (dev only) ─────────────────────────────────────────────────────────
PGADMIN_PASSWORD=admin

# ── SPRING BOOT (when you add the backend service) ────────────────────────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/fluxverde
# SPRING_DATASOURCE_USERNAME=fluxverde
# SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}
